<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tambah tombol "Generate DOCX" ke header form RPS -->
    <record id="view_bp_edu_rps_generate_inherit" model="ir.ui.view">
        <field name="name">bp.edu.rps.form.generate.inherit</field>
        <field name="model">bp.edu.rps</field>
        <field name="inherit_id" ref="bp_edu_rps.bp_edu_rps_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[1]" position="before">
                <button type="object"
                        name="action_generate_docx"
                        string="Generate DOCX"
                        icon="fa-file-word-o"/>
            </xpath>
        </field>
    </record>

    <!-- Tambah tombol "Generate DOCX" ke header form SAP -->
    <record id="view_bp_edu_sap_generate_inherit" model="ir.ui.view">
        <field name="name">bp.edu.sap.form.generate.inherit</field>
        <field name="model">bp.edu.sap</field>
        <field name="inherit_id" ref="bp_edu_rps.bp_edu_sap_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[1]" position="before">
                <button type="object"
                        name="action_generate_docx"
                        string="Generate DOCX"
                        icon="fa-file-word-o"/>
            </xpath>
        </field>
    </record>

    <!-- Tambah tombol "Generate DOCX" ke header form Kontrak Kuliah -->
    <record id="view_bp_edu_kontrak_generate_inherit" model="ir.ui.view">
        <field name="name">bp.edu.kontrak.kuliah.form.generate.inherit</field>
        <field name="model">bp.edu.kontrak.kuliah</field>
        <field name="inherit_id" ref="bp_edu_rps.bp_edu_kontrak_kuliah_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[1]" position="before">
                <button type="object"
                        name="action_generate_docx"
                        string="Generate DOCX"
                        icon="fa-file-word-o"/>
            </xpath>
        </field>
    </record>

</odoo>
