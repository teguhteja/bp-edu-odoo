<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="ttm_tenant_view_list" model="ir.ui.view">
        <field name="name">ttm.tenant.list</field>
        <field name="model">ttm.tenant</field>
        <field name="arch" type="xml">
            <list string="Tenants">
                <field name="name"/>
                <field name="name_database"/>
                <field name="subdomain"/>
                <field name="full_url"/>
                <field name="admin_email"/>
                <field name="group_tenant_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'error'"
                       decoration-warning="state == 'draft'"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ttm_tenant_view_form" model="ir.ui.view">
        <field name="name">ttm.tenant.form</field>
        <field name="model">ttm.tenant</field>
        <field name="arch" type="xml">
            <form string="Tenant">
                <header>
                    <button name="action_create_tenant" string="Buat Tenant"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Proses ini akan membuat database baru dan subdomain. Lanjutkan?"/>
                    <button name="action_create_tenant" string="Coba Lagi"
                            type="object" class="btn-warning"
                            invisible="state != 'error'"
                            confirm="Coba membuat tenant lagi?"/>
                    <button name="action_delete_tenant" string="Hapus Tenant"
                            type="object" class="btn-danger"
                            invisible="state != 'active'"
                            confirm="Ini akan menghapus database dan subdomain secara permanen. Yakin?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nama Tenant..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Konfigurasi Database">
                            <field name="name_database"
                                   readonly="state == 'active'"/>
                            <field name="subdomain"
                                   readonly="state == 'active'"/>
                            <field name="full_url" readonly="1"/>
                        </group>
                        <group string="Konfigurasi Admin">
                            <field name="admin_email"/>
                            <field name="admin_name"/>
                            <field name="admin_password" password="True"/>
                        </group>
                    </group>
                    <group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                            <field name="npm_proxy_host_id" readonly="1"/>
                        </group>
                        <group string="Tenant Group">
                            <field name="group_tenant_id"
                                   domain="[('user_ids', 'in', uid)]"
                                   options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Error" invisible="state != 'error'">
                            <field name="error_message" readonly="1"
                                   widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ttm_tenant_view_search" model="ir.ui.view">
        <field name="name">ttm.tenant.search</field>
        <field name="model">ttm.tenant</field>
        <field name="arch" type="xml">
            <search string="Cari Tenant">
                <field name="name"/>
                <field name="name_database"/>
                <field name="subdomain"/>
                <filter string="Aktif" name="active" domain="[('state','=','active')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Error" name="error" domain="[('state','=','error')]"/>
                <separator/>
                <filter string="Diarsipkan" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ttm_tenant" model="ir.actions.act_window">
        <field name="name">Tenants</field>
        <field name="res_model">ttm.tenant</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="ttm_tenant_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada tenant. Buat tenant pertama!
            </p>
            <p>
                Setiap tenant akan mendapatkan database Odoo baru
                dan subdomain yang dikonfigurasi otomatis.
            </p>
        </field>
    </record>

</odoo>
