<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form View Kontrak Kuliah ──────────────────────────── -->
    <record id="bp_edu_kontrak_kuliah_form_view" model="ir.ui.view">
        <field name="name">bp.edu.kontrak.kuliah.form</field>
        <field name="model">bp.edu.kontrak.kuliah</field>
        <field name="arch" type="xml">
            <form string="Kontrak Kuliah">
                <header>
                    <button name="action_buat_materi_kosong"
                            string="Generate 16 Baris Materi"
                            type="object"
                            invisible="materi_ids"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="mata_kuliah_id" string="Kontrak Kuliah"/>
                        <h1>
                            <field name="mata_kuliah_id"
                                   options="{'no_create': True}"
                                   placeholder="Pilih Mata Kuliah..."/>
                        </h1>
                    </div>

                    <!-- Identitas -->
                    <group>
                        <group string="Identitas">
                            <field name="dosen_id" options="{'no_create': True}"/>
                            <field name="tahun_akademik_id" options="{'no_create': True}"/>
                            <field name="periode"/>
                            <field name="kelas"/>
                            <field name="hari_jam" placeholder="Contoh: Selasa, 14:00 - 15:40"/>
                        </group>
                        <group string="Detail MK">
                            <field name="jenis_mk" placeholder="Contoh: Mata Kuliah Wajib Umum"/>
                            <field name="prasyarat"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab: Penilaian -->
                        <page string="Penilaian" name="penilaian">
                            <group string="Bobot Penilaian (%)">
                                <group>
                                    <field name="bobot_diskusi"/>
                                    <field name="bobot_proyek"/>
                                    <field name="bobot_tugas"/>
                                </group>
                                <group>
                                    <field name="bobot_kuis"/>
                                    <field name="bobot_uts"/>
                                    <field name="bobot_uas"/>
                                </group>
                                <field name="total_bobot"
                                       decoration-danger="total_bobot != 100"
                                       decoration-success="total_bobot == 100"/>
                            </group>
                            <group string="Jumlah Penugasan">
                                <field name="jumlah_kuis_mingguan"/>
                                <field name="jumlah_tugas_terstruktur"/>
                                <field name="jumlah_proyek"/>
                            </group>
                        </page>

                        <!-- Tab: CPMK -->
                        <page string="CPMK" name="cpmk">
                            <field name="cpmk_ids" nolabel="1">
                                <list>
                                    <field name="kode"/>
                                    <field name="deskripsi"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Materi Per Minggu -->
                        <page string="Materi Per Minggu" name="materi">
                            <field name="materi_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="minggu" readonly="1"/>
                                    <field name="materi"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Wakil Mahasiswa -->
                        <page string="Wakil Mahasiswa" name="wakil">
                            <group>
                                <field name="wakil_mahasiswa"
                                       placeholder="Nama lengkap wakil mahasiswa"/>
                                <field name="nim_wakil" placeholder="NIM"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── List View ─────────────────────────────────────────── -->
    <record id="bp_edu_kontrak_kuliah_list_view" model="ir.ui.view">
        <field name="name">bp.edu.kontrak.kuliah.list</field>
        <field name="model">bp.edu.kontrak.kuliah</field>
        <field name="arch" type="xml">
            <list string="Kontrak Kuliah">
                <field name="mata_kuliah_id"/>
                <field name="dosen_id" optional="show"/>
                <field name="tahun_akademik_id" optional="show"/>
                <field name="periode" optional="show"/>
                <field name="kelas" optional="show"/>
                <field name="total_bobot"
                       optional="show"
                       decoration-danger="total_bobot != 100"/>
            </list>
        </field>
    </record>

    <!-- ─── Search View ───────────────────────────────────────── -->
    <record id="bp_edu_kontrak_kuliah_search_view" model="ir.ui.view">
        <field name="name">bp.edu.kontrak.kuliah.search</field>
        <field name="model">bp.edu.kontrak.kuliah</field>
        <field name="arch" type="xml">
            <search string="Cari Kontrak Kuliah">
                <field name="mata_kuliah_id"/>
                <field name="dosen_id"/>
                <field name="tahun_akademik_id"/>
                <group expand="0" string="Kelompokkan berdasarkan">
                    <filter string="Tahun Akademik" name="group_ta"
                            context="{'group_by': 'tahun_akademik_id'}"/>
                    <filter string="Dosen" name="group_dosen"
                            context="{'group_by': 'dosen_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────── -->
    <record id="bp_edu_kontrak_kuliah_action" model="ir.actions.act_window">
        <field name="name">Kontrak Kuliah</field>
        <field name="res_model">bp.edu.kontrak.kuliah</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bp_edu_kontrak_kuliah_search_view"/>
    </record>

</odoo>
