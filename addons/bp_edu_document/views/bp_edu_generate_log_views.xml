<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_bp_edu_generate_log_list" model="ir.ui.view">
        <field name="name">bp.edu.generate.log.list</field>
        <field name="model">bp.edu.generate.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="name"/>
                <field name="document_type" widget="badge"/>
                <field name="mata_kuliah_id"/>
                <field name="template_id"/>
                <field name="user_id"/>
                <button name="action_download" type="object" string="Unduh" icon="fa-download"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bp_edu_generate_log_form" model="ir.ui.view">
        <field name="name">bp.edu.generate.log.form</field>
        <field name="model">bp.edu.generate.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_download" type="object"
                                class="oe_stat_button" icon="fa-download">
                            <span>Unduh</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="document_type" widget="badge"/>
                            <field name="mata_kuliah_id"/>
                            <field name="template_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="create_date"/>
                            <field name="attachment_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bp_edu_generate_log" model="ir.actions.act_window">
        <field name="name">History Generate</field>
        <field name="res_model">bp.edu.generate.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
