<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="ttm_tenant_group_view_list" model="ir.ui.view">
        <field name="name">ttm.tenant.group.list</field>
        <field name="model">ttm.tenant.group</field>
        <field name="arch" type="xml">
            <list string="Tenant Groups">
                <field name="name"/>
                <field name="description"/>
                <field name="tenant_count" string="Tenant"/>
                <field name="user_count" string="User"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ttm_tenant_group_view_form" model="ir.ui.view">
        <field name="name">ttm.tenant.group.form</field>
        <field name="model">ttm.tenant.group</field>
        <field name="arch" type="xml">
            <form string="Tenant Group">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nama group, mis. kelas-a..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="description" placeholder="Deskripsi group..."/>
                    </group>
                    <notebook>
                        <page string="Tenants" name="tenants">
                            <field name="tenant_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="name_database"/>
                                    <field name="full_url"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-danger="state == 'error'"
                                           decoration-warning="state == 'draft'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Users" name="users">
                            <field name="user_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="login"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ttm_tenant_group_view_search" model="ir.ui.view">
        <field name="name">ttm.tenant.group.search</field>
        <field name="model">ttm.tenant.group</field>
        <field name="arch" type="xml">
            <search string="Cari Tenant Group">
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ttm_tenant_group" model="ir.actions.act_window">
        <field name="name">Tenant Groups</field>
        <field name="res_model">ttm.tenant.group</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="ttm_tenant_group_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada tenant group. Buat group pertama!
            </p>
            <p>
                Contoh: kelas-a, kelas-b, premium, basic.
                Setiap group bisa dikaitkan ke beberapa tenant dan beberapa user.
            </p>
        </field>
    </record>

</odoo>
