<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit form Mata Kuliah (bp_edu_curriculum) untuk menambah:
        - Smart buttons: jumlah RPS, SAP, dan Kontrak Kuliah
        - Tombol aksi cepat buat RPS/SAP/Kontrak baru
    -->
    <record id="bp_edu_mata_kuliah_rps_inherit" model="ir.ui.view">
        <field name="name">bp.edu.mata.kuliah.rps.inherit</field>
        <field name="model">bp.edu.mata.kuliah</field>
        <field name="inherit_id" ref="bp_edu_curriculum.bp_edu_mata_kuliah_form_view"/>
        <field name="arch" type="xml">
            <!-- Tambah stat buttons di atas form -->
            <xpath expr="//sheet/div[@class='oe_title']" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_rps"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text">
                        <field name="rps_count" string="RPS" widget="statinfo"/>
                    </button>
                    <button name="action_view_sap"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-alt">
                        <field name="sap_count" string="SAP" widget="statinfo"/>
                    </button>
                    <button name="action_view_kontrak"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-handshake-o">
                        <field name="kontrak_count" string="Kontrak" widget="statinfo"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
