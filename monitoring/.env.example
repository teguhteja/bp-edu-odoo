# ══════════════════════════════════════════════════════════════
#  CaritaHub Monitoring Stack – Environment Variables
#  Salin file ini ke .env lalu edit sebelum menjalankan setup.sh
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
#  GlitchTip (Sentry-compatible error tracker)
# ──────────────────────────────────────────────────────────────

# Secret key – WAJIB diubah! Generate dengan:
#   python3 -c "import secrets; print(secrets.token_hex(50))"
GLITCHTIP_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_100_CHAR_STRING

# Password database GlitchTip
GLITCHTIP_DB_PASSWORD=CHANGE_THIS_DB_PASSWORD

# Port web UI GlitchTip
GLITCHTIP_PORT=8100

# Domain publik GlitchTip (dipakai di URL email notifikasi)
# Contoh: https://sentry.yourdomain.com
GLITCHTIP_DOMAIN=http://localhost:8100

# Email pengirim notifikasi
GLITCHTIP_FROM_EMAIL=alerts@yourdomain.com

# ──────────────────────────────────────────────────────────────
#  Mailpit (SMTP Email Catcher)
# ──────────────────────────────────────────────────────────────
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# ──────────────────────────────────────────────────────────────
#  Dozzle (Container Log Viewer)
# ──────────────────────────────────────────────────────────────
DOZZLE_PORT=9999

# ──────────────────────────────────────────────────────────────
#  Odoo Docker Network
#
#  Cari nama dengan: docker network ls
#  Default jika folder project = bp-edu-odoo: bp-edu-odoo_default
# ──────────────────────────────────────────────────────────────
# Setelah menambahkan explicit network di docker-compose.yml utama,
# namanya menjadi: odoo_app
ODOO_NETWORK=odoo_app
