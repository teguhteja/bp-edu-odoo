<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="ttm_user_tenant_view_list" model="ir.ui.view">
        <field name="name">ttm.user.tenant.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="User Manage Tenant">
                <field name="name" string="Nama"/>
                <field name="login"/>
                <field name="email"/>
                <field name="group_tenant_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ttm_user_tenant_view_form" model="ir.ui.view">
        <field name="name">ttm.user.tenant.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="User Manage Tenant">
                <sheet>
                    <field name="image_1920" widget="image"
                           class="oe_avatar" readonly="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <field name="login" readonly="1"/>
                    </div>
                    <group>
                        <group string="Info User">
                            <field name="email" readonly="1"/>
                            <field name="active" widget="boolean_toggle" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tenant Groups">
                        <field name="group_tenant_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"
                               nolabel="1"/>
                    </group>
                    <group string="Tenant Groups (Detail)">
                        <field name="group_tenant_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="description"/>
                                <field name="tenant_count" string="Tenant"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ttm_user_tenant_view_search" model="ir.ui.view">
        <field name="name">ttm.user.tenant.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search string="Cari User">
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="group_tenant_ids" string="Tenant Group"/>
                <filter string="Punya Tenant Group" name="has_group"
                        domain="[('group_tenant_ids','!=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ttm_user_tenant" model="ir.actions.act_window">
        <field name="name">User Manage Tenant</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('ttm_user_tenant_view_list')}),
            (0,0,{'view_mode':'form','view_id':ref('ttm_user_tenant_view_form')})]"/>
        <field name="search_view_id" ref="ttm_user_tenant_view_search"/>
        <field name="domain">[('share', '=', False)]</field>
        <field name="context">{'search_default_has_group': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada user internal.
            </p>
            <p>
                Tambahkan user lalu berikan Tenant Group
                agar mereka bisa mengakses tenant yang sesuai.
            </p>
        </field>
    </record>

</odoo>
