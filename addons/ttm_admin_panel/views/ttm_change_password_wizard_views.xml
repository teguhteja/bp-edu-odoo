<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ttm_change_password_wizard_view_form" model="ir.ui.view">
        <field name="name">ttm.change.password.wizard.form</field>
        <field name="model">ttm.change.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Ganti Password Admin Tenant">
                <sheet>
                    <group>
                        <field name="tenant_id" readonly="1"/>
                        <field name="new_password" widget="password" password="True"/>
                        <field name="confirm_password" widget="password" password="True"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Simpan Password"
                            type="object" class="btn-primary"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
