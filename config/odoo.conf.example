[options]
; Master password for database management
admin_passwd = PLEASE_USE_SECURE_PASSWORD

; Addon paths: Odoo built-in + custom addons + third-party
addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/extra-addons/addons,/mnt/extra-addons/third-party,/mnt/extra-addons/third-party/crm_lead_firstname-18.0.1.0.0,/mnt/extra-addons/third-party/partner_contact_birthdate-18.0.1.0.0

; Database connection
db_host = db
db_port = 5432
db_user = odoo
db_password = odoo

; Active database
db_name = odoo

; Allow database selection at login screen
list_db = True

; Workers
workers = 2

; Trust proxy headers (X-Forwarded-*) from nginx
proxy_mode = True

; Log to stdout (for docker logs)
logfile = False
