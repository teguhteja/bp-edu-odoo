<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form View ─────────────────────────────────────────── -->
    <record id="bp_edu_dosen_form_view" model="ir.ui.view">
        <field name="name">bp.edu.dosen.form</field>
        <field name="model">bp.edu.dosen</field>
        <field name="arch" type="xml">
            <form string="Dosen">
                <sheet>
                    <div class="oe_title">
                        <label for="nama" string="Nama Dosen"/>
                        <h1>
                            <field name="nama" placeholder="Nama lengkap dengan gelar"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identitas">
                            <field name="nidn"/>
                            <field name="nuptk"/>
                            <field name="email"/>
                        </group>
                        <group string="Kepegawaian">
                            <field name="pangkat_golongan"/>
                            <field name="jabatan"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Tanda Tangan">
                        <field name="tanda_tangan"
                               widget="image"
                               options="{'size': [200, 100]}"
                               filename="tanda_tangan_filename"/>
                        <field name="tanda_tangan_filename" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── List View ─────────────────────────────────────────── -->
    <record id="bp_edu_dosen_list_view" model="ir.ui.view">
        <field name="name">bp.edu.dosen.list</field>
        <field name="model">bp.edu.dosen</field>
        <field name="arch" type="xml">
            <list string="Dosen">
                <field name="nama"/>
                <field name="nidn"/>
                <field name="nuptk"/>
                <field name="jabatan"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- ─── Search View ───────────────────────────────────────── -->
    <record id="bp_edu_dosen_search_view" model="ir.ui.view">
        <field name="name">bp.edu.dosen.search</field>
        <field name="model">bp.edu.dosen</field>
        <field name="arch" type="xml">
            <search string="Cari Dosen">
                <field name="nama"/>
                <field name="nidn"/>
                <field name="nuptk"/>
                <field name="jabatan"/>
                <filter string="Aktif" name="aktif" domain="[('active', '=', True)]"/>
                <filter string="Non-Aktif" name="nonaktif" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────── -->
    <record id="bp_edu_dosen_action" model="ir.actions.act_window">
        <field name="name">Dosen</field>
        <field name="res_model">bp.edu.dosen</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bp_edu_dosen_search_view"/>
        <field name="context">{'search_default_aktif': 1}</field>
    </record>

</odoo>
