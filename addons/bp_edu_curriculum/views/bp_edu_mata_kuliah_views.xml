<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form View Mata Kuliah ─────────────────────────────── -->
    <record id="bp_edu_mata_kuliah_form_view" model="ir.ui.view">
        <field name="name">bp.edu.mata.kuliah.form</field>
        <field name="model">bp.edu.mata.kuliah</field>
        <field name="arch" type="xml">
            <form string="Mata Kuliah">
                <sheet>
                    <div class="oe_title">
                        <label for="nama" string="Mata Kuliah"/>
                        <h1>
                            <field name="nama" placeholder="Nama mata kuliah"/>
                        </h1>
                        <h4>
                            <field name="kode" placeholder="Kode MK" style="width: 120px;"/>
                        </h4>
                    </div>

                    <!-- Informasi Umum -->
                    <group>
                        <group string="Informasi MK">
                            <field name="prodi_id"/>
                            <field name="semester"/>
                            <field name="status"/>
                            <field name="kategori"/>
                            <field name="matakuliah_syarat"/>
                        </group>
                        <group string="SKS">
                            <field name="sks_teori"/>
                            <field name="sks_praktik"/>
                            <field name="sks_total"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab: CPL & CPMK -->
                        <page string="CPL &amp; CPMK" name="cpl_cpmk">
                            <field name="cpl_ids" widget="many2many_tags"
                                   options="{'color_field': 'tipe'}"/>

                            <separator string="CPMK"/>
                            <field name="cpmk_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="kode" optional="show"/>
                                    <field name="cpl_text" string="CPL" optional="show"/>
                                    <field name="deskripsi"/>
                                </list>
                                <form string="CPMK">
                                    <group>
                                        <field name="kode"/>
                                        <field name="cpl_text" string="CPL (teks)"/>
                                        <field name="cpl_ids" widget="many2many_tags"/>
                                    </group>
                                    <field name="deskripsi" placeholder="Deskripsi CPMK..."/>
                                    <separator string="Sub-CPMK"/>
                                    <field name="sub_cpmk_ids">
                                        <list editable="bottom">
                                            <field name="kode"/>
                                            <field name="minggu" optional="show"/>
                                            <field name="level_bloom" optional="show"/>
                                            <field name="deskripsi"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>

                        <!-- Tab: Deskripsi -->
                        <page string="Deskripsi" name="deskripsi">
                            <group string="Deskripsi Singkat">
                                <field name="deskripsi_singkat" nolabel="1"
                                       placeholder="Deskripsi singkat mata kuliah..."/>
                            </group>
                            <group string="Bahan Kajian">
                                <field name="bahan_kajian" nolabel="1"
                                       placeholder="1. Topik pertama&#10;2. Topik kedua&#10;..."/>
                            </group>
                        </page>

                        <!-- Tab: Pustaka -->
                        <page string="Pustaka" name="pustaka">
                            <field name="pustaka_ids" nolabel="1">
                                <list editable="bottom" decoration-info="jenis == 'Utama'">
                                    <field name="kode" optional="show"/>
                                    <field name="jenis"/>
                                    <field name="referensi"/>
                                </list>
                                <form string="Pustaka">
                                    <group>
                                        <field name="kode"/>
                                        <field name="jenis"/>
                                    </group>
                                    <field name="referensi" placeholder="Teks referensi lengkap (format APA/Chicago)"/>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── List View ─────────────────────────────────────────── -->
    <record id="bp_edu_mata_kuliah_list_view" model="ir.ui.view">
        <field name="name">bp.edu.mata.kuliah.list</field>
        <field name="model">bp.edu.mata.kuliah</field>
        <field name="arch" type="xml">
            <list string="Mata Kuliah">
                <field name="kode"/>
                <field name="nama"/>
                <field name="semester" optional="show"/>
                <field name="sks_total" optional="show"/>
                <field name="status" optional="show"/>
                <field name="kategori" optional="hide"/>
                <field name="prodi_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ─── Search View ───────────────────────────────────────── -->
    <record id="bp_edu_mata_kuliah_search_view" model="ir.ui.view">
        <field name="name">bp.edu.mata.kuliah.search</field>
        <field name="model">bp.edu.mata.kuliah</field>
        <field name="arch" type="xml">
            <search string="Cari Mata Kuliah">
                <field name="kode"/>
                <field name="nama"/>
                <field name="prodi_id"/>
                <filter string="Wajib" name="wajib" domain="[('status', '=', 'Wajib')]"/>
                <filter string="Pilihan" name="pilihan" domain="[('status', '=', 'Pilihan')]"/>
                <separator/>
                <filter string="Semester 1" name="sem1" domain="[('semester', '=', 1)]"/>
                <filter string="Semester 2" name="sem2" domain="[('semester', '=', 2)]"/>
                <filter string="Semester 3" name="sem3" domain="[('semester', '=', 3)]"/>
                <filter string="Semester 4" name="sem4" domain="[('semester', '=', 4)]"/>
                <group expand="0" string="Kelompokkan berdasarkan">
                    <filter string="Semester" name="group_semester" context="{'group_by': 'semester'}"/>
                    <filter string="Program Studi" name="group_prodi" context="{'group_by': 'prodi_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────── -->
    <record id="bp_edu_mata_kuliah_action" model="ir.actions.act_window">
        <field name="name">Mata Kuliah</field>
        <field name="res_model">bp.edu.mata.kuliah</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bp_edu_mata_kuliah_search_view"/>
    </record>

</odoo>
